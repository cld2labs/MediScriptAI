# Local development (without Docker): export these in your shell — do not rely
# on .env files inside frontend/ or backend/.
#
#   export OPENAI_API_KEY=sk-your-key
#   export BACKEND_INTERNAL_URL=http://127.0.0.1:8000
#
# For Docker, set OPENAI_API_KEY in your environment before:
#   docker compose up --build
# Optional model overrides are documented in docker-compose.yml.

OPENAI_API_KEY=your_openai_api_key_here
